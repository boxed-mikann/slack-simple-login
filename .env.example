# Example environment variables for apps/slack-simple-login
# Copy to .env.local for local development or set in Vercel Project Environment Variables

# Public app URL (used to build login link)
APP_URL=https://your-app.vercel.app

# Slack secrets
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# HMAC secret used to sign short-lived login tokens
LOGIN_LINK_SECRET=replace-with-a-secure-random-value

# Optional: when testing locally with ngrok, set this to your ngrok url (http/https)
# and update APP_URL accordingly when running locally.
NGROK_URL=http://xxxx.ngrok.io
