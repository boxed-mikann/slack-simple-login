{
  "display_information": {
    "name": "Slack Simple Login PoC",
    "description": "PoC: issue short-lived login links from Slack and sign into a Vercel web app.",
    "background_color": "#08111f"
  },
  "features": {
    "bot_user": {
      "display_name": "SimpleLoginBot",
      "always_online": false
    },
    "slash_commands": [
      {
        "command": "/login",
        "url":"https://<your-app>/api/slack/link",
        "description": "Issue a short-lived login link for the PoC web app",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://<your-app>/api/slack/link"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "event_subscriptions": {
      "request_url": "https://<your-app>/api/slack/link"
    }
  }
}
